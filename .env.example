# Copy this file to `.env` and replace the placeholder values with your real keys.
# Do NOT commit your real `.env` file to git. `.env` is already listed in `.gitignore`.

# Your Anthropic / Claude API key.
# Keep this secret. Example: CLAUDE_API_KEY=sk-xxx
CLAUDE_API_KEY=

# Optional: port for the server proxy (default: 3000)
PORT=3000
